# Engine that handles messages: deterministic | tool-agent | multi-agent
ENGINE=deterministic

# tool-agent only: stream a progress line per tool call to the IDE (off by default)
SHOW_TOOL_TRACE=false

# Ollama generation model and server base URL
MODEL=qwen2.5
# Embedding model: must match the index; re-index if you change it
# (a small dedicated model is faster, e.g. ollama pull nomic-embed-text)
EMBED_MODEL=qwen3
OLLAMA_URL=http://localhost:11435

# RAG: number of retrieved chunks and chunk size in words
TOP_K=3
MAX_WORDS=300

# Generation context window (Ollama num_ctx); lower = less memory, faster
CONTEXT_LENGTH=4096

# Indexing (storage script): topic and folder to index
COLLECTION=dask
DOCS_FOLDER=data/documents/dask
