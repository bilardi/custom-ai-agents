# Engine that handles messages: deterministic | tool-agent | agent-as-tool (multi-agent later)
ENGINE=deterministic

# tool-agent/agent-as-tool: stream a progress line per tool call to the IDE (off by default)
SHOW_TOOL_TRACE=false

# Ollama generation model and server base URL. Agents reach it via /v1 (reliable
# tool-calling). llama3.2:3b is the best small local orchestrator (fast, delegates).
MODEL=llama3.2:3b
# agent-as-tool only: model for the coder sub-agent. Same model for all roles fits
# ~6 GB of VRAM; set CODER_MODEL=coding for better code if you have room.
CODER_MODEL=llama3.2:3b
# agent-as-tool only: opt-in LLM reviewer of the coder's output (off by default).
# On a small model it flags everything (no signal, see benchmark/reviewer.md); the
# coder's deterministic check (syntax/ruff) stays. Enable with a capable REVIEWER_MODEL.
REVIEW=false
REVIEWER_MODEL=llama3.2:3b
# Embedding model: must match the index; re-index if you change it.
# A dedicated retrieval model beats a general LLM and is much faster to index
# (ollama pull nomic-embed-text)
EMBED_MODEL=nomic-embed-text
OLLAMA_URL=http://localhost:11435

# RAG: retrieved chunks per query, chunk size and overlap in words.
# Larger chunks keep an articulated topic whole and rank better; overlap helps
# only when chunks are small enough to split a topic (0 is best with MAX_WORDS=500)
TOP_K=3
MAX_WORDS=500
OVERLAP=0

# Generation context window (Ollama num_ctx); lower = less memory, faster
CONTEXT_LENGTH=4096

# Indexing (storage script): topic and folder to index; RESET=true wipes the
# collection before indexing (re-index from scratch), otherwise it appends
COLLECTION=dask
DOCS_FOLDER=data/documents/dask
RESET=false
